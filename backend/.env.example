# =============================================================================
# AIRA Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=AIRA Backend
APP_ENV=development
DEBUG=false
API_V1_STR=/api/v1

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (development)
DATABASE_URL=postgresql://aira_z1ts_user:sYl1UBIiZPz65MRgz9dRAmVCnoe2F0bD@dpg-d6ike8ggjchc73dd6na0-a/aira_z1ts
# PostgreSQL (production): DATABASE_URL=postgresql://user:password@localhost:5432/aira_db
# MySQL: DATABASE_URL=mysql+pymysql://user:password@localhost:3306/aira_db

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=K1b0MAGnJiIXDjLnW3wQmnSp9QIFNR1v94PsbdIWNX4PVtBHoW6oUnFMhDodlspfs2xz_9TQbWLNUGzze9eyWg
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Admin Bootstrap
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@aira.local
ADMIN_PASSWORD=ChangeMe!123

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM)
# -----------------------------------------------------------------------------
# Generate: python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# If blank, auto-generates into MASTER_KEY_FILE
ADMIN_MASTER_KEY_B64=vCJtAd2wo1SH1UGvI7uUnVe10fhHMRq42p9TcDAFj4c=
MASTER_KEY_FILE=.aira_master_key
TRANSPORT_ENCRYPTION_ENABLED=true
HEALTH_INCLUDE_DETAILS=false

# -----------------------------------------------------------------------------
# Google AI (Gemini)
# -----------------------------------------------------------------------------
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyBINWoZCl0iDWWkw42VLTFIh8F9EV4A8-w
# Note: model catalog changes over time. If you see 404 model-not-found, run ListModels.
# Safe default as of 2026: gemini-flash-latest (maps to models/gemini-flash-latest).
GEMINI_MODEL=gemini-flash-latest
CHAT_CONTEXT_WINDOW=8
SYSTEM_PROMPT=You are a professional academic research assistant. Respond concisely, formally, and with scientific integrity.

# Hugging Face (optional, prevents rate-limit warnings for model downloads)
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# -----------------------------------------------------------------------------
# AWS S3 (leave empty for local storage)
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Local Storage (used when S3 is not configured)
# -----------------------------------------------------------------------------
LOCAL_STORAGE_PATH=local_storage
LOCAL_STORAGE_CLEANUP_DAYS=90

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=20
# Comma-separated list of allowed MIME types (empty = allow all)
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/gif,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# -----------------------------------------------------------------------------
# API Security Hardening
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_TOOLS_MAX=40
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_DEFAULT_MAX=120

SECURITY_HEADERS_ENABLED=true
CSP_POLICY=default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:;

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

